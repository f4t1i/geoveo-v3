{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "get_route input",
  "type": "object",
  "properties": {
    "location": {
      "type": "string",
      "description": "Ort, Region oder textuelle Routenbeschreibung."
    },
    "mode": {
      "type": "string",
      "enum": [
        "drive",
        "walk",
        "bike"
      ],
      "default": "drive"
    },
    "sampling_meters": {
      "type": "number",
      "minimum": 1,
      "default": 15
    },
    "max_points": {
      "type": "integer",
      "minimum": 1,
      "default": 20
    }
  },
  "required": [
    "location"
  ],
  "additionalProperties": false
}
